{
  "name": "slice",
  "version": "0.1.0",
  "description": "Curated MCP servers for AI agents — generate MCP servers from OpenAPI specs with a simple UI",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently -n client,server -c blue,green \"pnpm dev:client\" \"pnpm dev:server\"",
    "dev:client": "vite",
    "dev:server": "tsx watch src/server/index.ts",
    "build": "pnpm build:client && pnpm build:server",
    "build:client": "tsc -p tsconfig.app.json && vite build",
    "build:server": "tsc -p tsconfig.server.json && pnpm copy:templates",
    "copy:templates": "node -e \"require('node:fs').cpSync('src/server/templates','dist/server/server/templates',{recursive:true})\"",
    "start": "NODE_ENV=production node dist/server/server/index.js",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "keywords": [
    "mcp",
    "openapi",
    "ai-agents",
    "code-generator"
  ],
  "author": "Cedric Gicquiaud",
  "license": "MIT",
  "dependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@hookform/resolvers": "^5.4.0",
    "archiver": "^8.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "handlebars": "^4.7.9",
    "js-yaml": "^4.1.1",
    "lucide-react": "^1.16.0",
    "multer": "^2.1.1",
    "postman-to-openapi": "^3.0.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-dropzone": "^15.0.0",
    "react-hook-form": "^7.76.1",
    "swagger2openapi": "^7.0.8",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/archiver": "^7.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@types/yauzl": "^2.10.3",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/ui": "^4.1.7",
    "concurrently": "^9.2.1",
    "js-tiktoken": "1.0.21",
    "jsdom": "^29.1.1",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7",
    "yauzl": "^3.3.1"
  }
}
