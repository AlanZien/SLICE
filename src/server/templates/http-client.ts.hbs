/**
 * Minimal HTTP wrapper that the generated MCP tools call into.
 * Generated by SLICE — do not edit by hand. Regenerate the bundle if the
 * upstream API or auth setup changes.
 */

const BASE_URL = process.env.UPSTREAM_BASE_URL ?? '';

if (!BASE_URL) {
  throw new Error('UPSTREAM_BASE_URL is required. Copy .env.example to .env and set it.');
}

{{#ifEquals upstreamAuth.type "apiKey"}}
const API_KEY_HEADER = '{{upstreamAuth.headerName}}';
const API_KEY = process.env.UPSTREAM_API_KEY ?? '';

if (!API_KEY) {
  throw new Error('UPSTREAM_API_KEY is required for this MCP.');
}
{{/ifEquals}}
{{#ifEquals upstreamAuth.type "bearer"}}
const BEARER_TOKEN = process.env.UPSTREAM_BEARER_TOKEN ?? '';

if (!BEARER_TOKEN) {
  throw new Error('UPSTREAM_BEARER_TOKEN is required for this MCP.');
}
{{/ifEquals}}

interface CallOptions {
  method: 'GET' | 'POST' | 'PUT' | 'PATCH' | 'DELETE';
  /** Path template with `{name}` placeholders matching `pathParams`. */
  path: string;
  pathParams?: Record<string, string | number>;
  query?: Record<string, unknown>;
  body?: unknown;
}

/**
 * Issue a single upstream call and return the parsed JSON body.
 * Errors above 2xx are surfaced verbatim so the agent can react.
 */
export async function call({ method, path, pathParams, query, body }: CallOptions): Promise<unknown> {
  let url = path;
  if (pathParams) {
    for (const [name, value] of Object.entries(pathParams)) {
      url = url.replace(`{${name}}`, encodeURIComponent(String(value)));
    }
  }
  const search = new URLSearchParams();
  if (query) {
    for (const [name, value] of Object.entries(query)) {
      if (value === undefined || value === null) continue;
      search.append(name, String(value));
    }
  }
  const qs = search.toString();
  const fullUrl = `${BASE_URL}${url}${qs ? `?${qs}` : ''}`;

  const headers: Record<string, string> = {
    Accept: 'application/json',
    'Content-Type': 'application/json',
  };
  {{#ifEquals upstreamAuth.type "apiKey"}}
  headers[API_KEY_HEADER] = API_KEY;
  {{/ifEquals}}
  {{#ifEquals upstreamAuth.type "bearer"}}
  headers.Authorization = `Bearer ${BEARER_TOKEN}`;
  {{/ifEquals}}

  const res = await fetch(fullUrl, {
    method,
    headers,
    body: body === undefined ? undefined : JSON.stringify(body),
  });

  if (!res.ok) {
    const text = await res.text();
    throw new Error(`Upstream ${res.status} ${res.statusText}: ${text}`);
  }

  const ct = res.headers.get('content-type') ?? '';
  if (ct.includes('application/json')) {
    return res.json();
  }
  return res.text();
}
