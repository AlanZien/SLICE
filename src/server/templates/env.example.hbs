# Base URL for the upstream {{apiName}} API.
UPSTREAM_BASE_URL={{baseUrl}}
{{#ifEquals upstreamAuth.type "apiKey"}}

# Forwarded to the upstream API as `{{upstreamAuth.headerName}}: <value>`.
UPSTREAM_API_KEY=
{{/ifEquals}}
{{#ifEquals upstreamAuth.type "bearer"}}

# Forwarded to the upstream API as `Authorization: Bearer <value>`.
UPSTREAM_BEARER_TOKEN=
{{/ifEquals}}
{{#if mcpServerToken}}

# Required when the MCP exposes its HTTP transport. Agents must send
# this value as `Authorization: Bearer <value>` to reach the server.
MCP_SERVER_TOKEN={{mcpServerToken}}
{{/if}}
{{#unless modeLocalOnly}}

# Port the HTTP transport binds to. Default 8787 matches the README.
MCP_HTTP_PORT=8787
{{/unless}}
